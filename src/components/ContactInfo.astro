---
const address = "Mitre 516, Concepción del Uruguay";
const phone = "+54 3442 35449903";
const email = "email@gmail.com";
const facebook = "https://www.facebook.com/federico.molachino.3?fref=ts";
const instagram = "https://www.instagram.com/arq_federico_molachino/";
const linkedin = "https://www.linkedin.com/in/usuario/";
const officeHours = "Lunes a Viernes: 9:00 - 18:00";
const specializations = "Diseño arquitectónico, Consultoría en planificación urbana, Desarrollo de proyectos residenciales y comerciales.";
---

<article id="contact" class="grid gap-8 md:gap-16 grid-cols-1 md:grid-cols-2 bg-white/50 rounded-2xl p-4 md:p-8 reveal opacity-0 translate-x-12">
  <aside class="grid grid-rows-[auto,1fr,auto] gap-8">
    <div class="grid gap-2">
      <h2 class="font-semibold text-3xl md:text-4xl tracking-tight">Contacto</h2>
      <p class="text-[#1a1a1a]/70 text-balance">
        Ante cualquier consulta no dude en enviarnos un mensaje.
      </p>
      <p class="text-[#1a1a1a]/70 text-balance mt-4">
        <strong class="font-medium">Horario de Atención:</strong> {officeHours}
      </p>
      <p class="text-[#1a1a1a]/70 text-balance mt-4">
        <strong class="font-medium">Especialización:</strong> {specializations}
      </p>
    </div>
    <div class="self-center grid gap-4">
      <div class="flex gap-4 items-center">
        <div class="grid gap-1 text-sm md:text-base">
          <a href={`https://wa.me/${phone}`} class="flex items-center gap-2 hover:text-lime transition-colors">
            <img src="/icons/whatsapp.svg" alt="WhatsApp" class="w-6 h-6" />
            <span>{phone}</span>
          </a>
        </div>
      </div>
      <div class="flex gap-4">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6 text-[#1a1a1a]/40">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 10.55l-9.751 5.475-9.75-5.475V18h19.5V10.55zM3.375 6.675h17.25a.75.75 0 0 1 .75.75v13.5a.75.75 0 0 1-.75.75H3.375a.75.75 0 0 1-.75-.75v-13.5a.75.75 0 0 1 .75-.75z" />
          </svg>
        <a class="text-sm md:text-base hover:text-lime transition-colors" href={`mailto:${email}`}>{email}</a>
      </div>
      <div class="flex items-center gap-2 text-sm text-[#6B6B6B]">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
          <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" />
        </svg>
        <span>{address}</span>
      </div>
    </div>
    <div>
      <h3 class="font-semibold text-sm text-[#6B6B6B] uppercase tracking-wider mb-4">Síguenos en redes</h3>
      <ul class="flex gap-4">
        <li>
          <a
            class="opacity-40 hover:opacity-100 hover:text-lime transition-all"
            href={facebook}
            target="_blank"
            rel="noopener noreferrer"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-facebook">
              <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path>
            </svg>
          </a>
        </li>
        <li>
          <a
            class="opacity-40 hover:opacity-100 hover:text-lime transition-all"
            href={instagram}
            target="_blank"
            rel="noopener noreferrer"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-instagram">
              <rect width="20" height="20" x="2" y="2" rx="5" ry="5"></rect>
              <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
              <line x1="17.5" x2="17.51" y1="6.5" y2="6.5"></line>
            </svg>
          </a>
        </li>
        <li>
          <a
            class="opacity-40 hover:opacity-100 hover:text-lime transition-all"
            href={linkedin}
            target="_blank"
            rel="noopener noreferrer"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-linkedin">
              <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path>
              <rect width="4" height="12" x="2" y="9"></rect>
              <circle cx="4" cy="4" r="2"></circle>
            </svg>
          </a>
        </li>
      </ul>
    </div>
  </aside>
  <aside class="mt-8 md:mt-0">
    <iframe 
      src={`https://www.google.com/maps?q=${encodeURIComponent(address)}&output=embed`} 
      width="100%" 
      height="350" 
      class="rounded-xl"
      style="border:0;" 
      allowfullscreen="" 
      loading="lazy">
    </iframe>
  </aside>
</article>
