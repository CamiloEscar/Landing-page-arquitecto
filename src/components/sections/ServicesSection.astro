---
interface Service {
  icon: string;
  title: string;
  description: string;
  link?: string;
  image?: string;
}

interface Props {
  services?: Service[];
}

const defaultServices: Service[] = [
  {
    icon: "home",
    title: "Diseño y construcción de viviendas",
    description: "Diseñamos y ejecutamos tu casa ideal, desde el primer boceto hasta la entrega final de obra",
    link: "#servicios",
    image: "/images/Diseno_construccion_de_viviendas.jpg",
  },
  {
    icon: "building",
    title: "Proyectos comerciales",
    description: "Locales, oficinas y espacios de trabajo diseñados y construidos para tu negocio",
    link: "#servicios",
    image: "/images/proyectos_comerciales.jpg",
  },
  {
    icon: "hammer",
    title: "Remodelaciones con obra",
    description: "Renovamos espacios existentes con seguimiento completo de construcción",
    link: "#servicios",
    image: "/images/Remodelaciones_con_obra.jpg",
  },
  {
    icon: "construction",
    title: "Dirección y supervisión de obra",
    description: "Supervisamos tu obra para garantizar calidad, plazos y presupuesto",
    link: "#servicios",
    image: "/images/direccion-de-obra.webp",
  },
  {
    icon: "expand",
    title: "Ampliaciones",
    description: "Expandí tu hogar con seguimiento de obra integral",
    link: "#servicios",
    image: "/images/ampliaciones_de_obra.jpg",
  },
  //agregar pisos y revestimientos, etc
];

const { services = defaultServices } = Astro.props;

const iconMap: Record<string, string> = {
  home: "Home",
  building: "Building2",
  hammer: "Hammer",
  expand: "Expand",
  clipboard: "ClipboardList",
  construction: "Construction",
};
---

<section id="servicios" class="py-16 md:py-24 bg-white relative overflow-hidden">
  <!-- Subtle pattern -->
  <div class="absolute inset-0 opacity-[0.02]" style="background-image: radial-gradient(circle at 1px 1px, #000 1px, transparent 0); background-size: 30px 30px;"></div>
  
  <div class="max-w-screen-xl mx-auto px-6 md:px-12 relative">
    <!-- Section Header -->
    <div class="mb-12 reveal-up opacity-0 translate-y-8">
      <span class="text-sm font-mono text-[#7EDC2F] uppercase tracking-[0.2em]">Servicios</span>
    </div>
    
    <div class="flex flex-col md:flex-row md:items-end md:justify-between mb-8 gap-4">
      <div>
        <h2 class="font-bold text-4xl md:text-5xl text-[#1a1a1a] mb-4 reveal-up opacity-0 translate-y-8">
          ¿Qué hacemos?
        </h2>
        <p class="text-[#6B6B6B] text-lg max-w-lg reveal-up opacity-0 translate-y-8 delay-100">
          Diseñamos espacios que transforman la manera en que vivís. Cada proyecto es único, cada solución a tu medida.
        </p>
      </div>
    </div>

    <!-- Intro line -->
    <div class="mb-10 p-6 bg-[#F8F8F8] rounded-xl border-l-4 border-[#8CFF2E] reveal-up opacity-0 translate-y-8 delay-200">
      <p class="text-[#1a1a1a] text-lg">
        <span class="font-semibold">Desde el diseño hasta la entrega final</span> — acompañamos cada etapa de tu proyecto con dirección de obra incluida.
      </p>
    </div>

    <!-- Services Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {services.map((service, _index) => (
        <div 
            class="group relative p-6 bg-white border border-[#E5E5E5] rounded-2xl transition-all duration-300 
            hover:border-[#7EDC2F]/70 hover:shadow-xl hover:shadow-[#7EDC2F]/20 hover:-translate-y-1 
            reveal-up opacity-0 translate-y-8 min-h-[180px]"
          >
            <!-- 🔥 BACKGROUND IMAGE (VA PRIMERO) -->
          {service.image && (
            <div class="absolute inset-0 overflow-hidden rounded-2xl">
              <img
                src={service.image}
                alt={service.title}
                class="w-full h-full object-cover opacity-20 group-hover:opacity-40 transition-all duration-500"
              />
            </div>
          )}

          <!-- 🔥 OVERLAY (MUY IMPORTANTE) -->
          <div class="absolute inset-0 bg-white/30 group-hover:bg-white/5 transition-colors rounded-2xl"></div>
          <div class="relative z-10">
            <div class="flex items-start gap-4">
            <!-- Icon -->
            <div class="w-12 h-12 rounded-xl bg-[#7EDC2F]/15 flex items-center justify-center group-hover:bg-[#4CAF1A]/25 transition-colors">
              {iconMap[service.icon] === "Home" && (
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#7EDC2F" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M15 21v-8a1 1 0 0 0-1-1h-4a1 1 0 0 0-1 1v8"/><path d="M3 10a2 2 0 0 1 .709-1.528l7-5.999a2 2 0 0 1 2.582 0l7 5.999A2 2 0 0 1 21 10v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
                </svg>
              )}
              {iconMap[service.icon] === "Building2" && (
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#7EDC2F" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <rect width="16" height="20" x="4" y="2" rx="2" ry="2"/><path d="M9 22v-4h6v4"/><path d="M8 6h.01"/><path d="M16 6h.01"/><path d="M12 6h.01"/><path d="M12 10h.01"/><path d="M12 14h.01"/><path d="M16 10h.01"/><path d="M16 14h.01"/><path d="M8 10h.01"/><path d="M8 14h.01"/>
                </svg>
              )}
              {iconMap[service.icon] === "Hammer" && (
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#7EDC2F" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="m15 12-8.5 8.5c-.83.83-2.17.83-3 0 0 0 0 0 0 0a2.12 2.12 0 0 1-3 0L3 16v-2h2l9.5-9.5a2.12 2.12 0 0 1 3 0c.83.83.83 2.17 0 3Z"/>
                </svg>
              )}
              {iconMap[service.icon] === "Expand" && (
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#7EDC2F" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="m21 21-6-6m6 6v-4.8m0 4.8h-4.8"/><path d="M3 16.2V21m0 0h4.8M3 21l6-6"/><path d="M21 7.8V3m0 0h-4.8M21 3l-6 6"/><path d="M3 7.8V3m0 0h4.8M3 3l6 6"/>
                </svg>
              )}
              {iconMap[service.icon] === "ClipboardList" && (
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#7EDC2F" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <rect width="8" height="4" x="8" y="2" rx="1" ry="1"/><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/><path d="M12 11h4"/><path d="M12 16h4"/><path d="M8 11h.01"/><path d="M8 16h.01"/>
                </svg>
              )}
              {iconMap[service.icon] === "Construction" && (
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#7EDC2F" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M2 20a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V8l-7 5V8l-7 5V4a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2Z"/><path d="M17 18h1"/><path d="M12 18h1"/><path d="M7 18h1"/>
                </svg>
              )}
            </div>
            <div>
            <!-- Title -->
            <h3 class="font-semibold text-lg text-[#7EDC2F] mb-2 group-hover:text-[#4CAF1A] transition-colors">
              {service.title}
            </h3>
            </div>
            </div>
            <!-- Description -->
            <p class="text-[#6B6B6B] text-sm leading-relaxed">
              {service.description}
            </p>
          </div>


          <!-- Decorative corner -->
          <div class="absolute top-0 right-0 w-12 h-12 opacity-0 group-hover:opacity-100 transition-opacity">
            <div class="absolute top-3 right-3 w-6 h-6 border-t-2 border-r-2 border-[#8CFF2E] rounded-tr-lg"></div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .reveal-up {
    animation: fadeInUp 0.6s ease-out forwards;
  }

  .delay-100 {
    animation-delay: 100ms;
  }

  .delay-200 {
    animation-delay: 200ms;
  }
</style>
