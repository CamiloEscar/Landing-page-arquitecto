---
interface Props {
  architectName?: string;
  specialization?: string;
  availability?: string;
  yearsActive?: string;
}

const {
  architectName = "Federico Molachino",
  specialization = "Arquitecto y constructor",
  availability = "Disponible para proyectos",
  // yearsActive = "+15 años",
} = Astro.props;

const stats = [
  { value: "15+", label: "Años de experiencia" },
  { value: "200+", label: "Proyectos ejecutados" },
  { value: "100%", label: "Obras entregadas" },
  { value: "100+", label: "Clientes satisfechos" },
];
---

<section class="py-8 md:py-12 bg-white relative overflow-hidden">
  <!-- Subtle background pattern -->
  <div
    class="absolute inset-0 opacity-[0.03]"
    style="background-image: radial-gradient(circle at 1px 1px, #000 1px, transparent 0); background-size: 30px 30px;"
  >
  </div>

  <!-- Accent line -->
  <div
    class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-[#8CFF2E] to-transparent"
  >
  </div>

  <div class="max-w-screen-xl mx-auto px-6 md:px-12 relative">
    <!-- Stats Grid -->
    <div class="grid grid-cols-2 md:grid-cols-2 lg:grid-cols-4 gap-6 md:gap-8">
      {
        stats.map((stat, index) => (
          <div
            class="text-center p-4 reveal-up opacity-0 translate-y-8"
            style={`animation-delay: ${index * 100}ms`}
          >
            <div class="font-display text-3xl md:text-4xl lg:text-5xl text-[#8CFF2E] mb-1">
              {stat.value}
            </div>
            <div class="text-xs md:text-sm text-[#6B6B6B] font-mono uppercase tracking-wider">
              {stat.label}
            </div>
          </div>
        ))
      }
    </div>

    <!-- Info bar below -->
    <div class="mt-10 pt-8 border-t border-[#E5E5E5]">
      <div
        class="flex flex-col md:flex-row md:items-center md:justify-between gap-4"
      >
        <div class="reveal-up opacity-0 translate-y-8 delay-300">
          <p class="text-[#1a1a1a] font-semibold text-lg">
            {architectName} — {specialization}
          </p>
          <p class="text-[#8CFF2E] font-medium">
            {availability}
          </p>
        </div>

        <div class="reveal-up opacity-0 translate-y-8 delay-400">
          <a
            href="#contact"
            class="inline-flex items-center gap-2 px-6 py-3 bg-[#1a1a1a] text-white font-medium rounded-lg hover:bg-[#1a1a1a]/90 transition-all duration-300 hover:scale-105"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path>
            </svg>
            Consultar proyecto
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .reveal-up {
    animation: fadeInUp 0.6s ease-out forwards;
  }

  .delay-100 {
    animation-delay: 100ms;
  }
</style>
