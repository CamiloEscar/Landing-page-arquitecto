---
import type { Testimonial } from "../../types";

interface Props {
  testimonials?: Testimonial[];
}

const defaultTestimonials: Testimonial[] = [
  {
    client: "María García",
    project: "Casa Familiar",
    quote: "El equipo transformó completamente nuestra visión. El resultado superó todas las expectativas, creando un espacio que se siente como hogar desde el primer día.",
    rating: 5,
  },
  {
    client: "Carlos Rodríguez",
    project: "Oficina Corporate",
    quote: "Profesionalismo y calidad en cada detalle. El proyecto se entregó en tiempo y forma, con un diseño que ha mejorado significativamente nuestro ambiente de trabajo.",
    rating: 5,
  },
  {
    client: "Ana Martínez",
    project: "Remodelación Loft",
    quote: "Su enfoque innovador y atención al cliente hicieron posible transformar nuestro espacio en algo realmente único. Recomendación total.",
    rating: 5,
  },
];

const { testimonials = defaultTestimonials } = Astro.props;
---

<section class="w-full py-8 md:py-12 bg-gradient-to-b from-[#F8F8F8] to-white overflow-hidden">
  <div class="max-w-screen-xl mx-auto px-6 md:px-12">
    <!-- Section Header with Label -->
    <div class="mb-12 reveal-up opacity-0 translate-y-8">
      <span class="text-sm font-mono text-[#8CFF2E] uppercase tracking-[0.2em]">Testimonios</span>
    </div>
    
    <div class="flex flex-col md:flex-row md:items-end md:justify-between mb-12 gap-4">
      <h2
        class="font-bold text-4xl md:text-5xl text-[#1a1a1a] reveal-up opacity-0 translate-y-8"
      >
        Lo que dicen<br class="hidden md:block" /> nuestros clientes
      </h2>
      <p
        class="text-[#6B6B6B] text-lg max-w-md reveal-up opacity-0 translate-y-8 delay-100"
      >
        Experiencias que respaldan nuestro trabajo
      </p>
    </div>

    <!-- Testimonials Carousel -->
    <div class="relative w-full max-w-4xl mx-auto">
      <!-- Testimonials Container with overflow hidden -->
      <div 
        class="testimonials-track overflow-hidden"
      >
        <div 
          class="testimonials-inner flex transition-transform duration-700 ease-out"
          data-autoplay="6000"
        >
          {testimonials.map((testimonial, _index) => (
            <div class="testimonial-slide w-full flex-shrink-0 px-2 md:px-4">
              <div class="bg-white rounded-xl p-6 md:p-10 shadow-lg">
                <!-- Quote Mark Decoration -->
                <div class="text-[#8CFF2E] text-5xl font-serif mb-4 opacity-50">
                  "
                </div>

                <!-- Quote Text -->
                <blockquote class="text-lg md:text-xl text-[#1a1a1a] leading-relaxed mb-6">
                  {testimonial.quote}
                </blockquote>

                <!-- Client Info -->
                <div class="flex items-center gap-4">
                  <!-- Avatar -->
                  <div class="w-12 h-12 rounded-full bg-[#8CFF2E] flex items-center justify-center">
                    <span class="font-bold text-[#1a1a1a]">
                      {testimonial.client.charAt(0)}
                    </span>
                  </div>

                  <div>
                    <cite class="not-italic font-semibold text-[#1a1a1a]">
                      {testimonial.client}
                    </cite>
                    <p class="text-sm text-[#6B6B6B]">{testimonial.project}</p>
                  </div>
                </div>

                <!-- Star Rating -->
                <div class="flex gap-1 mt-4">
                  {[...Array(5)].map((_, i) => (
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      width="18"
                      height="18"
                      viewBox="0 0 24 24"
                      fill={i < testimonial.rating ? "#8CFF2E" : "none"}
                      stroke="#8CFF2E"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    >
                      <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2" />
                    </svg>
                  ))}
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Navigation Dots -->
      <div class="flex justify-center gap-2 mt-6">
        {testimonials.map((_, index) => (
          <button
            class={`w-2.5 h-2.5 rounded-full transition-all duration-300 ${
              index === 0 ? "bg-[#8CFF2E] w-6" : "bg-[#E5E5E5] hover:bg-[#8CFF2E]/50"
            }`}
            data-dot-index={index}
            aria-label={`Go to testimonial ${index + 1}`}
          />
        ))}
      </div>

      <!-- Navigation Arrows -->
      <button
        class="absolute top-1/2 -left-2 md:-left-8 -translate-y-1/2 w-10 h-10 rounded-full bg-white shadow-lg flex items-center justify-center hover:bg-[#8CFF2E] transition-colors z-10"
        data-prev
        aria-label="Previous testimonial"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="m15 18-6-6 6-6"/>
        </svg>
      </button>
      <button
        class="absolute top-1/2 -right-2 md:-right-8 -translate-y-1/2 w-10 h-10 rounded-full bg-white shadow-lg flex items-center justify-center hover:bg-[#8CFF2E] transition-colors z-10"
        data-next
        aria-label="Next testimonial"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="m9 18 6-6-6-6"/>
        </svg>
      </button>
    </div>
  </div>
</section>

<!-- Testimonials Auto-rotation Script -->
<script>
  function initTestimonials() {
    const track = document.querySelector(".testimonials-inner") as HTMLElement;
    if (!track) return;

    const dots = document.querySelectorAll("[data-dot-index]") as NodeListOf<HTMLButtonElement>;
    const prevBtn = document.querySelector("[data-prev]") as HTMLButtonElement;
    const nextBtn = document.querySelector("[data-next]") as HTMLButtonElement;

    const slides = track.querySelectorAll(".testimonial-slide") as NodeListOf<HTMLElement>;
    const autoplayInterval = parseInt(track.dataset.autoplay || "6000", 10);
    
    let currentIndex = 0;
    let intervalId: number;

    function goToSlide(index: number) {
      currentIndex = index;
      track.style.transform = `translateX(-${index * 100}%)`;
      
      // Update dots
      dots.forEach((dot, i) => {
        if (i === index) {
          dot.classList.remove("bg-[#E5E5E5]");
          dot.classList.add("bg-[#8CFF2E]", "w-6");
        } else {
          dot.classList.remove("bg-[#8CFF2E]", "w-6");
          dot.classList.add("bg-[#E5E5E5]");
        }
      });
    }

    function nextSlide() {
      goToSlide((currentIndex + 1) % slides.length);
    }

    function prevSlide() {
      goToSlide((currentIndex - 1 + slides.length) % slides.length);
    }

    // Start autoplay
    function startAutoplay() {
      intervalId = window.setInterval(nextSlide, autoplayInterval);
    }

    function stopAutoplay() {
      clearInterval(intervalId);
    }

    // Event listeners
    nextBtn?.addEventListener("click", () => {
      stopAutoplay();
      nextSlide();
      startAutoplay();
    });

    prevBtn?.addEventListener("click", () => {
      stopAutoplay();
      prevSlide();
      startAutoplay();
    });

    dots.forEach((dot, index) => {
      dot.addEventListener("click", () => {
        stopAutoplay();
        goToSlide(index);
        startAutoplay();
      });
    });

    // Pause on hover
    const container = document.querySelector(".testimonials-track");
    container?.addEventListener("mouseenter", stopAutoplay);
    container?.addEventListener("mouseleave", startAutoplay);

    // Initialize first dot state
    goToSlide(0);
    
    // Start
    startAutoplay();
  }

  // Initialize on page load
  initTestimonials();

  // Re-initialize after view transitions
  document.addEventListener("astro:after-swap", initTestimonials);
</script>
