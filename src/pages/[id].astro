---
import ModelViewer from "../components/ModelViewer.astro";
import api from "../api";
import Badge from "../components/Badge.astro";
import Layout from "../Layout.astro";

const { project } = Astro.props;

export async function getStaticPaths() {
  const projects = await api.list();

  return projects.map((project) => ({
    params: {
      id: project.id,
    },
    props: {
      project,
    },
  }));
}

const projects = await api.list();
const currentIndex = projects.findIndex((p) => p.id === project.id);
const prevProject = currentIndex > 0 ? projects[currentIndex - 1] : null;
const nextProject = currentIndex < projects.length - 1 ? projects[currentIndex + 1] : null;

const allProjectImages = [...project.images, ...project.images2].filter(Boolean);
---

<Layout title={project.title} description={project.description || `Proyecto ${project.title} - ${project.category} en ${project.location || 'ubicación no especificada'}`}>
  <!-- Full-width Hero Image -->
  <section class="relative h-[85vh] min-h-[600px] overflow-hidden">
    <!-- Hero Image with Ken Burns effect -->
    <div class="absolute inset-0">
      <img
        src={allProjectImages[0]}
        alt={project.title}
        class="w-full h-full object-cover animate-ken-burns"
      />
      <!-- Gradient Overlay -->
      <div class="absolute inset-0 bg-gradient-to-t from-[#1a1a1a]/90 via-[#1a1a1a]/40 to-[#1a1a1a]/20"></div>
    </div>
    
    <!-- Floating Back Button -->
    <div class="absolute top-6 left-6 z-20">
      <a href="/proyectos" class="inline-flex items-center gap-2 px-4 py-2 bg-white/10 backdrop-blur-md border border-white/20 text-white rounded-full hover:bg-white/20 transition-all duration-300">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M19 12H5M12 19l-7-7 7-7"/>
        </svg>
        <span class="font-medium text-sm">Volver</span>
      </a>
    </div>

    <!-- Hero Content -->
    <div class="absolute bottom-0 left-0 right-0 p-8 md:p-16">
      <div class="max-w-screen-xl mx-auto">
        <!-- Category & Status Badges -->
        <div class="flex flex-wrap gap-3 mb-6">
          <span class="px-4 py-1.5 bg-[#8CFF2E] text-[#1a1a1a] text-xs font-mono uppercase tracking-wider rounded-full font-semibold">
            {project.category}
          </span>
          <Badge intent={project.status === "obra terminada" ? "constructive" : "doubtful"}>
            {project.status}
          </Badge>
        </div>
        
        <!-- Large Title -->
        <h1 class="text-5xl md:text-7xl lg:text-8xl font-bold text-white tracking-tight mb-4 leading-none">
          {project.title}
        </h1>
        
        <!-- Location -->
        {project.location && (
          <p class="text-white/80 text-xl flex items-center gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-[#8CFF2E]">
              <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/>
              <circle cx="12" cy="10" r="3"/>
            </svg>
            {project.location}
          </p>
        )}
      </div>
    </div>

    <!-- Scroll Indicator -->
    <div class="absolute bottom-8 right-8 animate-bounce">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="opacity-60">
        <path d="M12 5v14M19 12l-7 7-7-7"/>
      </svg>
    </div>
  </section>

  <!-- Project Info Grid -->
  <section class="py-16 bg-white">
    <div class="max-w-screen-xl mx-auto px-6 md:px-12">
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-4">
        <!-- Location -->
        <div class="bg-[#F8F8F8] rounded-2xl p-6 border border-gray-100 hover:border-[#8CFF2E] transition-colors group">
          <div class="text-[#8CFF2E] mb-3 group-hover:scale-110 transition-transform">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/>
              <circle cx="12" cy="10" r="3"/>
            </svg>
          </div>
          <p class="text-xs text-[#6B6B6B] uppercase tracking-wider mb-1 font-mono">Ubicación</p>
          <p class="font-semibold text-[#1a1a1a] text-sm">{project.location || 'No especificada'}</p>
        </div>
        
        <!-- Category -->
        <div class="bg-[#F8F8F8] rounded-2xl p-6 border border-gray-100 hover:border-[#8CFF2E] transition-colors group">
          <div class="text-[#8CFF2E] mb-3 group-hover:scale-110 transition-transform">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M4 20h16a2 2 0 0 0 2-2V8a2 2 0 0 0-2-2h-7.93a2 2 0 0 1-1.66-.9l-.82-1.2A2 2 0 0 0 7.93 3H4a2 2 0 0 0-2 2v13c0 1.1.9 2 2 2Z"/>
            </svg>
          </div>
          <p class="text-xs text-[#6B6B6B] uppercase tracking-wider mb-1 font-mono">Categoría</p>
          <p class="font-semibold text-[#1a1a1a] text-sm">{project.category}</p>
        </div>
        
        <!-- Year -->
        <div class="bg-[#F8F8F8] rounded-2xl p-6 border border-gray-100 hover:border-[#8CFF2E] transition-colors group">
          <div class="text-[#8CFF2E] mb-3 group-hover:scale-110 transition-transform">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect width="18" height="18" x="3" y="4" rx="2" ry="2"/>
              <line x1="16" x2="16" y1="2" y2="6"/>
              <line x1="8" x2="8" y1="2" y2="6"/>
              <line x1="3" x2="21" y1="10" y2="10"/>
            </svg>
          </div>
          <p class="text-xs text-[#6B6B6B] uppercase tracking-wider mb-1 font-mono">Año</p>
          <p class="font-semibold text-[#1a1a1a] text-sm">{project.year || project.date || 'No especificado'}</p>
        </div>
        
        <!-- Size -->
        <div class="bg-[#F8F8F8] rounded-2xl p-6 border border-gray-100 hover:border-[#8CFF2E] transition-colors group">
          <div class="text-[#8CFF2E] mb-3 group-hover:scale-110 transition-transform">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect width="18" height="18" x="3" y="3" rx="2"/>
              <path d="M3 9h18"/>
              <path d="M9 21V9"/>
            </svg>
          </div>
          <p class="text-xs text-[#6B6B6B] uppercase tracking-wider mb-1 font-mono">Superficie</p>
          <p class="font-semibold text-[#1a1a1a] text-sm">{project.size || 'No especificada'}</p>
        </div>
        
        <!-- Cliente (Placeholder) -->
        <div class="bg-[#F8F8F8] rounded-2xl p-6 border border-gray-100 opacity-60">
          <div class="text-[#6B6B6B] mb-3">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/>
              <circle cx="12" cy="7" r="4"/>
            </svg>
          </div>
          <p class="text-xs text-[#6B6B6B] uppercase tracking-wider mb-1 font-mono">Cliente</p>
          <p class="font-semibold text-[#6B6B6B] text-sm">Próximamente</p>
        </div>
        
        <!-- Arquitecto (Placeholder) -->
        <div class="bg-[#F8F8F8] rounded-2xl p-6 border border-gray-100 opacity-60">
          <div class="text-[#6B6B6B] mb-3">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M3 21h18"/>
              <path d="M9 8h1"/>
              <path d="M9 12h1"/>
              <path d="M14 8h1"/>
              <path d="M14 12h1"/>
              <path d="M5 21V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v16"/>
            </svg>
          </div>
          <p class="text-xs text-[#6B6B6B] uppercase tracking-wider mb-1 font-mono">Arquitecto</p>
          <p class="font-semibold text-[#6B6B6B] text-sm">Próximamente</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Description Section -->
  <section class="py-16 bg-[#F8F8F8]">
    <div class="max-w-screen-xl mx-auto px-6 md:px-12">
      <div class="bg-white rounded-3xl p-8 md:p-12 border border-gray-100 shadow-sm">
        <div class="mb-8">
          <span class="text-sm font-mono text-[#8CFF2E] uppercase tracking-[0.2em]">Acerca del Proyecto</span>
          <h2 class="text-3xl md:text-4xl font-bold text-[#1a1a1a] mt-2">Descripción</h2>
        </div>
        <div class="prose prose-lg max-w-none">
          <p class="text-[#6B6B6B] text-lg leading-relaxed">
            {project.description || "Descripción del proyecto próximamente..."}
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Image Gallery -->
  <section class="py-16 bg-white">
    <div class="max-w-screen-xl mx-auto px-6 md:px-12">
      <div class="mb-10">
        <span class="text-sm font-mono text-[#8CFF2E] uppercase tracking-[0.2em]">Galería</span>
        <h2 class="text-3xl md:text-4xl font-bold text-[#1a1a1a] mt-2">Imágenes del Proyecto</h2>
      </div>
      
      <!-- Main Display Image -->
      <div class="main-image-container mb-6 relative group cursor-pointer" id="mainImageContainer">
        <img
          id="mainImage"
          src={allProjectImages[0]}
          alt={`${project.title} - Imagen principal`}
          class="w-full aspect-[16/9] object-cover rounded-2xl shadow-lg transition-transform duration-500 group-hover:scale-[1.005]"
        />
        <!-- Lightbox trigger overlay -->
        <div class="absolute inset-0 bg-black/0 group-hover:bg-black/10 transition-colors rounded-2xl flex items-center justify-center">
          <span class="opacity-0 group-hover:opacity-100 transition-opacity bg-white/90 px-4 py-2 rounded-full text-sm font-medium text-[#1a1a1a]">
            Click para ampliar
          </span>
        </div>
      </div>

      <!-- Thumbnail Strip -->
      <div class="flex gap-3 overflow-x-auto pb-2 thumbnail-strip scrollbar-hide">
        {allProjectImages.map((image, index) => (
          <button
            class={`thumbnail-btn shrink-0 w-32 h-20 rounded-xl overflow-hidden transition-all duration-200 cursor-pointer border-2 ${
              index === 0 ? "border-[#8CFF2E] opacity-100" : "border-transparent opacity-60 hover:opacity-100"
            }`}
            data-index={index}
            data-image={image}
          >
            <img
              src={image}
              alt={`Miniatura ${index + 1}`}
              class="w-full h-full object-cover"
            />
          </button>
        ))}
      </div>
    </div>
  </section>

  <!-- Placeholder Sections -->
  <section class="py-16 bg-[#F8F8F8]">
    <div class="max-w-screen-xl mx-auto px-6 md:px-12">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <!-- Materiales -->
        <div class="bg-white rounded-2xl p-8 border-2 border-dashed border-gray-200 hover:border-[#8CFF2E] transition-colors group">
          <div class="flex items-center gap-4 mb-4">
            <div class="w-12 h-12 rounded-xl bg-[#F8F8F8] flex items-center justify-center text-[#8CFF2E] group-hover:scale-110 transition-transform">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="m21.64 3.64-1.28-1.28a1.21 1.21 0 0 0-1.72 0L2.36 18.13a1.21 1.21 0 0 0 0 1.72l1.28 1.28a1.2 1.2 0 0 0 1.72 0L21.64 5.36a1.2 1.2 0 0 0 0-1.72Z"/>
                <path d="m14 7 2 2"/>
                <path d="m20 4 2 2"/>
              </svg>
            </div>
            <div>
              <span class="text-xs font-mono text-[#8CFF2E] uppercase tracking-wider">Detalles</span>
              <h3 class="text-xl font-bold text-[#1a1a1a]">Materiales Utilizados</h3>
            </div>
          </div>
          <p class="text-[#6B6B6B]">Descubre los materiales de construcción y acabados seleccionados para este proyecto.</p>
          <p class="text-xs text-[#8CFF2E] font-mono mt-4">Próximamente →</p>
        </div>

        <!-- Especificaciones -->
        <div class="bg-white rounded-2xl p-8 border-2 border-dashed border-gray-200 hover:border-[#8CFF2E] transition-colors group">
          <div class="flex items-center gap-4 mb-4">
            <div class="w-12 h-12 rounded-xl bg-[#F8F8F8] flex items-center justify-center text-[#8CFF2E] group-hover:scale-110 transition-transform">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/>
              </svg>
            </div>
            <div>
              <span class="text-xs font-mono text-[#8CFF2E] uppercase tracking-wider">Técnico</span>
              <h3 class="text-xl font-bold text-[#1a1a1a]">Especificaciones Técnicas</h3>
            </div>
          </div>
          <p class="text-[#6B6B6B]">Planos, esquemas y especificaciones detalladas del proyecto arquitectónico.</p>
          <p class="text-xs text-[#8CFF2E] font-mono mt-4">Próximamente →</p>
        </div>

        <!-- Equipo -->
        <div class="bg-white rounded-2xl p-8 border-2 border-dashed border-gray-200 hover:border-[#8CFF2E] transition-colors group">
          <div class="flex items-center gap-4 mb-4">
            <div class="w-12 h-12 rounded-xl bg-[#F8F8F8] flex items-center justify-center text-[#8CFF2E] group-hover:scale-110 transition-transform">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/>
                <circle cx="9" cy="7" r="4"/>
                <path d="M22 21v-2a4 4 0 0 0-3-3.87"/>
                <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
              </svg>
            </div>
            <div>
              <span class="text-xs font-mono text-[#8CFF2E] uppercase tracking-wider">Equipo</span>
              <h3 class="text-xl font-bold text-[#1a1a1a]">Equipo de Proyecto</h3>
            </div>
          </div>
          <p class="text-[#6B6B6B]">Arquitectos, diseñadores e ingenieros que desarrollaron este proyecto.</p>
          <p class="text-xs text-[#8CFF2E] font-mono mt-4">Próximamente →</p>
        </div>

        <!-- Proceso -->
        <div class="bg-white rounded-2xl p-8 border-2 border-dashed border-gray-200 hover:border-[#8CFF2E] transition-colors group">
          <div class="flex items-center gap-4 mb-4">
            <div class="w-12 h-12 rounded-xl bg-[#F8F8F8] flex items-center justify-center text-[#8CFF2E] group-hover:scale-110 transition-transform">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 20h9"/>
                <path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/>
              </svg>
            </div>
            <div>
              <span class="text-xs font-mono text-[#8CFF2E] uppercase tracking-wider">Proceso</span>
              <h3 class="text-xl font-bold text-[#1a1a1a]">Proceso de Diseño</h3>
            </div>
          </div>
          <p class="text-[#6B6B6B]">Del boceto a la realidad — evolución del concepto arquitectónico.</p>
          <p class="text-xs text-[#8CFF2E] font-mono mt-4">Próximamente →</p>
        </div>
      </div>
    </div>
  </section>

  <!-- 3D Model Viewer -->
  {project.modelUrl && (
    <section class="py-16 bg-white">
      <div class="max-w-screen-xl mx-auto px-6 md:px-12">
        <div class="mb-10">
          <span class="text-sm font-mono text-[#8CFF2E] uppercase tracking-[0.2em]">Tecnología</span>
          <h2 class="text-3xl md:text-4xl font-bold text-[#1a1a1a] mt-2">Modelo 3D Interactivo</h2>
        </div>
        <ModelViewer
          src={project.modelUrl}
          alt={project.title}
          autoRotate
          cameraControls
          style="width: 100%; height: 600px; max-width: 1200px; border-radius: 1.5rem;"
        />
      </div>
    </section>
  )}

  <!-- Project Navigation -->
  <section class="py-16 bg-[#F8F8F8]">
    <div class="max-w-screen-xl mx-auto px-6 md:px-12">
      <div class="flex flex-col md:flex-row gap-4">
        {prevProject ? (
          <a href={`/${prevProject.id}`} class="flex-1 bg-white rounded-2xl p-6 border border-gray-100 hover:border-[#8CFF2E] hover:shadow-lg transition-all duration-300 group">
            <p class="text-xs text-[#6B6B6B] uppercase tracking-wider mb-2 flex items-center gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M19 12H5M12 19l-7-7 7-7"/>
              </svg>
              Proyecto Anterior
            </p>
            <p class="font-bold text-[#1a1a1a] text-lg group-hover:text-[#8CFF2E] transition-colors">
              {prevProject.title}
            </p>
          </a>
        ) : (
          <div class="flex-1 bg-gray-100 rounded-2xl p-6 border border-gray-200 opacity-50">
            <p class="text-xs text-[#6B6B6B] uppercase tracking-wider mb-2">Proyecto Anterior</p>
            <p class="font-semibold text-[#6B6B6B]">No hay proyecto anterior</p>
          </div>
        )}
        
        {nextProject ? (
          <a href={`/${nextProject.id}`} class="flex-1 bg-white rounded-2xl p-6 border border-gray-100 hover:border-[#8CFF2E] hover:shadow-lg transition-all duration-300 group text-right">
            <p class="text-xs text-[#6B6B6B] uppercase tracking-wider mb-2 flex items-center justify-end gap-2">
              Proyecto Siguiente
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M5 12h14M12 5l7 7-7 7"/>
              </svg>
            </p>
            <p class="font-bold text-[#1a1a1a] text-lg group-hover:text-[#8CFF2E] transition-colors">
              {nextProject.title}
            </p>
          </a>
        ) : (
          <div class="flex-1 bg-gray-100 rounded-2xl p-6 border border-gray-200 opacity-50">
            <p class="text-xs text-[#6B6B6B] uppercase tracking-wider mb-2 text-right">Proyecto Siguiente</p>
            <p class="font-semibold text-[#6B6B6B] text-right">No hay siguiente proyecto</p>
          </div>
        )}
      </div>

      <!-- Back to all projects -->
      <div class="mt-8 text-center">
        <a href="/proyectos" class="inline-flex items-center gap-2 px-6 py-3 bg-[#1a1a1a] text-white rounded-full hover:bg-[#8CFF2E] hover:text-[#1a1a1a] transition-all duration-300 font-medium">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
            <polyline points="9 22 9 12 15 12 15 22"/>
          </svg>
          Volver a todos los proyectos
        </a>
      </div>
    </div>
  </section>

  <!-- Lightbox Modal -->
  <div id="lightbox" class="fixed inset-0 z-50 bg-black/95 hidden flex items-center justify-center p-4">
    <button id="closeLightbox" class="absolute top-6 right-6 text-white/80 hover:text-white transition-colors p-2">
      <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M18 6 6 18M6 6l12 12"/>
      </svg>
    </button>
    <img id="lightboxImage" src="" alt="Imagen ampliada" class="max-w-full max-h-[90vh] object-contain rounded-lg" />
  </div>
</Layout>

<style>
  @keyframes ken-burns {
    0% {
      transform: scale(1);
    }
    100% {
      transform: scale(1.1);
    }
  }
  
  .animate-ken-burns {
    animation: ken-burns 20s ease-out forwards;
  }

  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }
  
  .scrollbar-hide {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const mainImage = document.getElementById('mainImage') as HTMLImageElement | null;
    const mainImageContainer = document.getElementById('mainImageContainer');
    const thumbnails = document.querySelectorAll('.thumbnail-btn');
    const lightbox = document.getElementById('lightbox');
    const lightboxImage = document.getElementById('lightboxImage') as HTMLImageElement | null;
    const closeLightbox = document.getElementById('closeLightbox');
    
    // Thumbnail click handler
    if (mainImage && thumbnails.length > 0) {
      thumbnails.forEach((thumb) => {
        thumb.addEventListener('click', () => {
          const imageSrc = thumb.getAttribute('data-image');
          if (imageSrc && mainImage) {
            mainImage.src = imageSrc;
            
            // Update active state
            thumbnails.forEach((t) => {
              t.classList.remove('border-[#8CFF2E]', 'opacity-100');
              t.classList.add('border-transparent', 'opacity-60');
            });
            thumb.classList.remove('border-transparent', 'opacity-60');
            thumb.classList.add('border-[#8CFF2E]', 'opacity-100');
          }
        });
      });
    }

    // Lightbox functionality
    if (mainImageContainer && lightbox && lightboxImage && closeLightbox && mainImage) {
      mainImageContainer.addEventListener('click', () => {
        lightboxImage.src = mainImage.src;
        lightbox.classList.remove('hidden');
        document.body.style.overflow = 'hidden';
      });

      closeLightbox.addEventListener('click', () => {
        lightbox.classList.add('hidden');
        document.body.style.overflow = '';
      });

      lightbox.addEventListener('click', (e) => {
        if (e.target === lightbox) {
          lightbox.classList.add('hidden');
          document.body.style.overflow = '';
        }
      });

      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && !lightbox.classList.contains('hidden')) {
          lightbox.classList.add('hidden');
          document.body.style.overflow = '';
        }
      });
    }
  });
</script>