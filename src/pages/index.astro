---
import api from "../api";
import Layout from "../Layout.astro";

// Import section components
import HeroSection from "../components/sections/HeroSection.astro";
// import StatsSection from "../components/sections/StatsSection.astro";
import ServicesSection from "../components/sections/ServicesSection.astro";
import ProcessSection from "../components/sections/ProcessSection.astro";
import TechnologySection from "../components/sections/TechnologySection.astro";
import ProjectCarousel from "../components/react/ProjectCarousel";
import AboutSection from "../components/sections/AboutSection.astro";
import TestimonialsSection from "../components/sections/TestimonialsSection.astro";
import FAQSection from "../components/sections/FAQSection.astro";
import ContactInfo from "../components/ContactInfo.astro";
import ContactForm from "../components/ContactForm.astro";

// Fetch projects for carousel
let projects = await api.list();

// Sort and select featured projects
projects = projects.sort((a) => (a.featured ? -1 : 1)).slice(0, 6);

// Shuffle selected projects
projects = projects.sort(() => Math.random() - 0.5);
---

<Layout title="Estudio de Arquitectura">
  <div class="w-full">
    <!-- 1. Hero - Full screen with cycling text -->
    <HeroSection />

    <!-- 2. Stats - Brief credentials -->
    <!-- <StatsSection /> -->

    <!-- 3. Services - What we do -->
    <ServicesSection />

    <!-- 4. Process - How we work -->
    <ProcessSection />

    <!-- 5. Technology - Tools we use -->
    <TechnologySection />

    <!-- 6. Projects - Portfolio showcase -->
    <ProjectCarousel client:visible projects={projects} />

    <!-- 7. About - Brief intro -->
    <AboutSection />

    <!-- 8. Testimonials - Client reviews -->
    <TestimonialsSection />

    <!-- 9. FAQ - Common questions -->
    <FAQSection />

    <!-- 10. Contact - Contact form -->
    <section id="contact" class="w-full py-16 md:py-20 bg-[#F8F8F8]">
      <div class="max-w-screen-xl mx-auto px-6 md:px-12">
        <div class="mb-12">
          <span
            class="text-sm font-mono text-[#8CFF2E] uppercase tracking-[0.2em] reveal-up opacity-0 translate-y-8"
            >Contacto</span
          >
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16">
          <div class="reveal-up opacity-0 translate-y-8 delay-100">
            <ContactInfo />
          </div>
          <div class="reveal-up opacity-0 translate-y-8 delay-200">
            <ContactForm />
          </div>
        </div>
      </div>
    </section>
  </div>
</Layout>
